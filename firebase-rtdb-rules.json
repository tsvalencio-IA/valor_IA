{
  "rules": {
    ".read": false,
    ".write": false,

    "fornecedores": {
      ".read": "auth != null",
      ".write": "auth != null"
    },

    "cotacoes": {
      "$cotacaoId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    },

    "linksFornecedor": {
      "$cotacaoId": {
        "$fornecedorId": {
          "$token": {
            ".read": "data.exists()",
            ".write": "auth != null"
          }
        }
      }
    },

    "respostas": {
      "$cotacaoId": {
        ".read": "auth != null",
        "$fornecedorId": {
          "$token": {
            ".read": "auth != null || root.child('linksFornecedor/'+$cotacaoId+'/'+$fornecedorId+'/'+$token).exists()",
            ".write": "auth != null || root.child('linksFornecedor/'+$cotacaoId+'/'+$fornecedorId+'/'+$token).exists()"
          }
        }
      }
    }
  }
}
